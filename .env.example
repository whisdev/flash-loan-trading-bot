# ── RPC Endpoints (get free keys at https://alchemy.com) ─────────────────────
# Public fallbacks work for dry-run, but dedicated RPC keys are strongly recommended.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Wallet (required for LIVE mode only) ──────────────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Deployed contract address (required for LIVE mode only) ───────────────────
# Deploy contracts/FlashLoanArb.sol on Ethereum mainnet first, then paste here.
ARB_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── Bot settings ──────────────────────────────────────────────────────────────
# Set to "true" to scan only — no real transactions will be sent
DRY_RUN=true

# Minimum net profit (USD) to trigger execution
MIN_PROFIT_USD=30

# ── Redis cache (optional — falls back to in-memory when unavailable) ───────
REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_ENABLED=true
# REDIS_KEY_PREFIX=arb-scanner:
# REDIS_CACHE_TTL_SEC=30

# ── Telegram alerts (optional) ────────────────────────────────────────────────
# 1. Create a bot via @BotFather — copy the token here
# 2. Start a chat with your bot and get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
